  "components": {
    "appBar": {
      "base": {
        "background": {
          "light": "color.neutral.appbarBackground.light",
          "dark": "color.neutral.appbarBackground.dark"
        },
        "color": "color.text.appbar",
        "elevation": "1"
      }
    },
    "button": {
      "base": {
        "fontFamily": "typography.fontFamily.base",
        "fontSize": "typography.fontSize.button",
        "fontWeight": "typography.fontWeight.medium",
        "borderRadius": "radius.default",
        "letterSpacing": "0.02857em",
        "textTransform": "uppercase"
      },
      "variants": {
        "filled": {
          "primary": {
            "background": "color.brand.primary",
            "color": "#FFFFFF"
          }
        },
        "outlined": {
          "primary": {
            "background": "transparent",
            "color": "color.brand.primary",
            "border": {
              "width": "1px",
              "style": "solid",
              "color": "color.brand.primary"
            }
          }
        },
        "text": {
          "primary": {
            "background": "transparent",
            "color": "color.brand.primary"
          }
        }
      },
      "states": {
        "disabled": {
          "opacity": "0.38",
          "cursor": "not-allowed"
        }
      }
    },
    "card": {
      "base": {
        "background": "color.surface.surface",
        "borderRadius": "radius.default",
        "elevation": "1"
      },
      "variants": {
        "contrast": {
          "background": "color.surface.surface"
        }
      },
      "states": {
        "inactive": {
          "opacity": "0.6"
        }
      }
    },
    "dialog": {
      "base": {
        "borderRadius": "radius.default",
        "border": {
          "width": "1px",
          "style": "solid",
          "color": "color.border.dialog"
        }
      },
      "backdrop": {
        "backdropFilter": "blur(10px)"
      }
    },
    "drawer": {
