  "rules": [
    "Spacing follows a 4px base grid (MudBlazor spacing utilities: pa-1=4px through pa-16=64px)",
    "Brand color #E4022C is used uniformly for Primary, Secondary, and Tertiary — single brand color identity",
    "Default border radius is 2px for all components (set globally via LayoutProperties.DefaultBorderRadius)",
    "Headings (H1-H6) use 'Open Sans' font family; body/default text uses 'Montserrat'",
    "Drawer maintains light theme appearance in both light and dark modes (white background, dark text)",
    "Navigation active/hover state uses brand primary color with underline decoration (6px offset)",
    "Navigation link text uses font-weight 600 (semibold)",
    "Table headings use uppercase text transform with font-weight 700 (bold) in Open Sans",
    "Card and page headings use uppercase text transform with font-weight 800 (extrabold)",
    "Inactive/disabled entity rows and cards use opacity 0.6",
    "Dialogs use backdrop blur (10px) with a 1px white semi-transparent border",
    "Login page always renders in dark mode regardless of user preference",
    "Read-only form fields use gray background (#f5f5f5) and gray text (#757575) with not-allowed cursor",
    "MudContainer uses MaxWidth.ExtraExtraLarge for main content area with pa-4 padding",
    "App uses dual-mode theming (light/dark) with user preference persisted to database",
    "Main content area has pt-16 (64px) padding-top to clear the AppBar"
  ]
